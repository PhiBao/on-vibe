# === Phoenix Terminal v3 — Environment ===

# Solana RPC endpoint (public — used by frontend + API routes)
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# WalletConnect Project ID (optional — for WalletConnect support)
NEXT_PUBLIC_WC_PROJECT_ID=

# Markets to scan (comma-separated)
SYMBOLS=SOL,ETH,BTC

# Scan interval in seconds
SCAN_INTERVAL=60

# Risk settings
MAX_POSITION_PCT=5
MAX_DAILY_LOSS_PCT=10
MAX_LEVERAGE=20
INITIAL_PORTFOLIO=1000

# Position management
TRAILING_STOP_PCT=1.5
PARTIAL_PROFIT_PCT=2.0
BREAK_EVEN_TRIGGER=1.0
MAX_HOLD_BARS=48

# Minimum confidence to trade (0.0 - 1.0)
MIN_CONFIDENCE=0.55
