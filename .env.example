# === Phoenix Bot Environment ===

# Solana RPC (default: mainnet)
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# OpenAI API key (optional — for AI analysis, falls back to rule-based)
OPENAI_API_KEY=

# Trading mode: "paper" or "live"
TRADING_MODE=paper

# Markets to scan (comma-separated)
SYMBOLS=SOL,ETH,BTC

# Scan interval in seconds
SCAN_INTERVAL=60

# Risk settings
MAX_POSITION_PCT=5
MAX_DAILY_LOSS_PCT=10
MAX_LEVERAGE=3
INITIAL_PORTFOLIO=1000

# Position management
TRAILING_STOP_PCT=1.5
PARTIAL_PROFIT_PCT=2.0
BREAK_EVEN_TRIGGER=1.0
MAX_HOLD_BARS=48

# Minimum confidence to trade (0.0 - 1.0)
MIN_CONFIDENCE=0.55

# Solana wallet private key (ONLY for live trading — base58)
SOLANA_PRIVATE_KEY=
